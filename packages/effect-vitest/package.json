{
  "name": "@kbroom/effect-vitest",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "author": "Gerson Gallo <ggallovalle@gmail.com>",
  "description": "A Vitest fixture for testing Effect-based code with proper scope management. Automatically creates scopes, handles cleanup, and reports defects as test failures.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ggallovalle/chante.git",
    "directory": "packages/effect-vitest"
  },
  "bugs": {
    "url": "https://github.com/ggallovalle/chante/issues",
    "email": "ggallovalle@gmail.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsup",
    "test": "bunx --bun vitest run"
  },
  "peerDependencies": {
    "effect": "catalog:effect",
    "vitest": "catalog:vite"
  },
  "devDependencies": {
    "@types/bun": "catalog:typescript",
    "tsup": "catalog:typescript",
    "typescript": "catalog:typescript",
    "vitest": "catalog:vite"
  },
  "engines": {
    "bun": ">=1.2.14",
    "node": ">=18"
  }
}
