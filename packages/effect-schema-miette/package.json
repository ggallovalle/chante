{
  "name": "@kbroom/effect-schema-miette",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "author": "Gerson Gallo <ggallovalle@gmail.com>",
  "description": "Fancy error reporting for Effect, inspired by the Rust miette (https://github.com/zkat/miette) library. Provides Diagnostic, SourceCode, and GraphicalReportHandler for pretty terminal error output with source spans, labels, and severity levels, with Effect Schema integration.",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ggallovalle/chante.git",
    "directory": "packages/effect-schema-miette"
  },
  "bugs": {
    "url": "https://github.com/ggallovalle/chante/issues",
    "email": "ggallovalle@gmail.com"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./colors": {
      "import": "./src/colors.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.build.json",
    "build": "tsc -p tsconfig.build.json",
    "test": "bunx --bun vitest run"
  },
  "peerDependencies": {
    "effect": "catalog:effect"
  },
  "dependencies": {
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@kbroom/effect-vitest": "workspace:*",
    "@types/bun": "catalog:typescript",
    "typescript": "catalog:typescript",
    "vitest": "catalog:vite"
  },
  "engines": {
    "bun": ">=1.2.14",
    "node": ">=18"
  }
}
