{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".ts", ".tsx", ".json"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$", ".ts", ".tsx"],
      "cache": true
    },
    "test": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$", "test/**"],
      "cache": true
    }
  }
}
